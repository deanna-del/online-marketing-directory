---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { data } = post;
const { Content } = await post.render();

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: data.title,
  description: data.description,
  author: {
    '@type': 'Person',
    name: data.author,
  },
  datePublished: data.pubDate.toISOString(),
  image: data.featuredImage,
  publisher: {
    '@type': 'Organization',
    name: 'Online Marketing Directory',
    url: 'https://onlinemarketingdirectory.com',
  },
};
---

<BaseLayout
  title={`${data.title} — Online Marketing Directory`}
  description={data.description}
  ogImage={data.featuredImage}
  schema={schema}
>
  <article class="blog-post">
    <!-- Breadcrumb -->
    <nav class="breadcrumb-nav" aria-label="Breadcrumb">
      <div class="container">
        <ol class="breadcrumb">
          <li><a href="/">Home</a></li>
          <li aria-hidden="true">/</li>
          <li><a href="/blog">Blog</a></li>
          <li aria-hidden="true">/</li>
          <li aria-current="page">{data.title}</li>
        </ol>
      </div>
    </nav>

    <!-- Hero image -->
    {data.featuredImage && (
      <div class="post-hero-image">
        <img
          src={data.featuredImage}
          alt={data.title}
          width="1200"
          height="630"
          loading="eager"
        />
      </div>
    )}

    <!-- Post header -->
    <header class="post-header">
      <div class="container post-header-inner">
        {data.tags && data.tags.length > 0 && (
          <div class="post-tags">
            {data.tags.map((tag) => (
              <span class="post-tag">{tag}</span>
            ))}
          </div>
        )}
        <h1 class="post-title">{data.title}</h1>
        <p class="post-desc">{data.description}</p>
        <div class="post-meta">
          <div class="post-author-avatar" aria-hidden="true">{data.author.charAt(0)}</div>
          <div class="post-meta-info">
            <span class="post-author-name">{data.author}</span>
            <time class="post-date" datetime={data.pubDate.toISOString()}>
              {data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
          </div>
        </div>
      </div>
    </header>

    <!-- Post content -->
    <div class="post-content">
      <div class="container">
        <div class="post-layout">
          <div class="prose post-prose">
            <Content />
          </div>

          <aside class="post-sidebar">
            <div class="sidebar-cta-card">
              <h3>Browse the Tool Directory</h3>
              <p>Find the right tools for your online business with honest, in-depth reviews.</p>
              <a href="/tools" class="btn btn-primary btn-md">Browse Tools</a>
            </div>
            <div class="sidebar-cta-card">
              <h3>Recommended Training</h3>
              <p>Courses and programs from top online business educators.</p>
              <a href="/training" class="btn btn-secondary btn-md">View Training</a>
            </div>
          </aside>
        </div>

        <!-- Back link -->
        <div class="post-back">
          <a href="/blog" class="back-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="19" y1="12" x2="5" y2="12"></line>
              <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to Blog
          </a>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post { padding-bottom: 4rem; }

  .breadcrumb-nav {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: 0.625rem 0;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    flex-wrap: wrap;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .breadcrumb li { display: flex; align-items: center; }
  .breadcrumb a { color: var(--color-accent); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }
  .breadcrumb li:last-child { color: var(--color-text); }

  .post-hero-image {
    max-height: 460px;
    overflow: hidden;
    background: var(--color-surface);
  }

  .post-hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post-header {
    padding: 2.5rem 0 0;
  }

  .post-header-inner {
    max-width: 760px;
  }

  .post-tags {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .post-tag {
    background: var(--color-accent-light);
    color: var(--color-accent);
    padding: 0.2rem 0.625rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .post-title {
    font-size: clamp(1.625rem, 4vw, 2.5rem);
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1.2;
    margin-bottom: 0.875rem;
    letter-spacing: -0.02em;
  }

  .post-desc {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .post-author-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    font-size: 1rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .post-meta-info {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .post-author-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .post-date {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .post-content {
    padding-top: 2.5rem;
  }

  .post-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 3rem;
    align-items: start;
  }

  .post-prose {
    max-width: none;
  }

  .post-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: sticky;
    top: 80px;
  }

  .sidebar-cta-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem;
  }

  .sidebar-cta-card h3 {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .sidebar-cta-card p {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin-bottom: 0.875rem;
  }

  .sidebar-cta-card .btn { width: 100%; justify-content: center; }

  .post-back {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.15s;
  }

  .back-link:hover { color: var(--color-accent); }

  @media (max-width: 900px) {
    .post-layout { grid-template-columns: 1fr; }
    .post-sidebar {
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
    }
    .sidebar-cta-card { flex: 1; min-width: 220px; }
  }

  @media (max-width: 640px) {
    .post-sidebar { flex-direction: column; }
    .sidebar-cta-card { min-width: 100%; }
  }
</style>
