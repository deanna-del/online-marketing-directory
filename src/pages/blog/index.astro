---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<BaseLayout
  title="Blog — Online Marketing Directory"
  description="Practical guides, tool comparisons, and honest advice for coaches, course creators, and online business owners. No fluff — just what works."
>
  <div class="page-header">
    <div class="container">
      <h1 class="page-title">Blog</h1>
      <p class="page-intro">
        Practical guides, tool comparisons, and honest takes on what's working (and what's not)
        in the world of online coaching and course creation.
      </p>
    </div>
  </div>

  <div class="container section">
    <div class="posts-grid">
      {sortedPosts.map((post) => (
        <article class="post-card">
          {post.data.featuredImage && (
            <a href={`/blog/${post.slug}`} class="post-img-link" tabindex="-1" aria-hidden="true">
              <img
                src={post.data.featuredImage}
                alt=""
                class="post-img"
                width="600"
                height="338"
                loading="lazy"
              />
            </a>
          )}
          <div class="post-body">
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="post-tags">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="post-tag">{tag}</span>
                ))}
              </div>
            )}
            <h2 class="post-title">
              <a href={`/blog/${post.slug}`}>{post.data.title}</a>
            </h2>
            <p class="post-desc">{post.data.description}</p>
            <div class="post-meta">
              <span class="post-author">{post.data.author}</span>
              <span class="post-sep" aria-hidden="true">&middot;</span>
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
            </div>
            <a href={`/blog/${post.slug}`} class="post-read-more">
              Read article &rarr;
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page-header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: 3rem 0 2.5rem;
  }

  .page-title {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }

  .page-intro {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 600px;
    line-height: 1.65;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .post-card {
    background: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s, transform 0.15s;
  }

  .post-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  .post-img-link {
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-surface);
  }

  .post-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .post-card:hover .post-img { transform: scale(1.03); }

  .post-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    flex: 1;
  }

  .post-tags {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .post-tag {
    background: var(--color-accent-light);
    color: var(--color-accent);
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .post-title {
    font-size: 1.1875rem;
    font-weight: 700;
    line-height: 1.35;
  }

  .post-title a {
    color: var(--color-primary);
    text-decoration: none;
    transition: color 0.15s;
  }

  .post-title a:hover { color: var(--color-accent); }

  .post-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    flex: 1;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .post-author { font-weight: 500; }

  .post-read-more {
    color: var(--color-accent);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 600;
    transition: gap 0.15s;
  }

  .post-read-more:hover { text-decoration: underline; }

  @media (max-width: 768px) {
    .posts-grid { grid-template-columns: 1fr; }
  }
</style>
