---
interface Tool {
  slug: string;
  title: string;
  logo: string;
  category: string;
  subcategory: string;
  tagline: string;
  deannasPick: boolean;
  freePlan: 'Yes' | 'No' | 'Free Trial Only';
  startingPrice: string;
  affiliateUrl: string;
  categorySlug: string;
}

interface Props {
  tools: Tool[];
}

const { tools } = Astro.props;

const categories = [
  'Business Foundation',
  'Marketing & Lead Generation',
  'Content Creation',
  'AI Tools by Use Case',
  'Operations & Productivity',
];

const subcategoriesByCategory: Record<string, string[]> = {
  'Business Foundation': [
    'All-in-One Platforms',
    'Course & Membership Platforms',
    'Coaching & Client Management',
    'Payment & Checkout Tools',
  ],
  'Marketing & Lead Generation': [
    'Landing Page & Funnel Builders',
    'Email Marketing Platforms',
    'Social Media Management',
    'SEO & Analytics',
    'Podcast Tools',
    'Webinar & Live Event Tools',
  ],
  'Content Creation': [
    'AI Writing & Content Tools',
    'Design & Visual Tools',
    'Video Creation & Editing',
    'Screen Recording',
  ],
  'AI Tools by Use Case': [
    'AI Writing & Copywriting',
    'AI Image & Design Generation',
    'AI Video & Avatar Tools',
    'AI Automation & Workflows',
    'AI Research & SEO',
  ],
  'Operations & Productivity': [
    'Scheduling & Booking',
    'Project Management',
    'File Storage & Delivery',
    'Contract & Proposal Tools',
  ],
};

const allSubcategories = Object.values(subcategoriesByCategory).flat();
---

<div class="tool-search" id="tool-search">
  <div class="search-controls">
    <div class="search-input-wrap">
      <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <input
        type="search"
        id="tool-search-input"
        class="search-input"
        placeholder="Search tools by name, description, or category..."
        aria-label="Search tools"
        autocomplete="off"
      />
    </div>

    <div class="filter-row">
      <select id="filter-category" class="filter-select" aria-label="Filter by category">
        <option value="">All Categories</option>
        {categories.map((cat) => (
          <option value={cat}>{cat}</option>
        ))}
      </select>

      <select id="filter-subcategory" class="filter-select" aria-label="Filter by subcategory">
        <option value="">All Subcategories</option>
        {allSubcategories.map((sub) => (
          <option value={sub}>{sub}</option>
        ))}
      </select>

      <select id="filter-free-plan" class="filter-select" aria-label="Filter by free plan">
        <option value="">All Plans</option>
        <option value="Yes">Free Plan Available</option>
        <option value="Free Trial Only">Free Trial Only</option>
        <option value="No">Paid Only</option>
      </select>

      <button id="clear-filters" class="clear-btn" type="button" aria-label="Clear all filters">
        Clear Filters
      </button>
    </div>
  </div>

  <div class="search-results-bar">
    <p class="results-count" id="results-count" aria-live="polite">
      Showing <strong id="results-num">{tools.length}</strong> tools
    </p>
  </div>
</div>

<script define:vars={{ subcategoriesByCategory }}>
  document.addEventListener('DOMContentLoaded', () => {
  const searchInput = document.getElementById('tool-search-input');
  const filterCategory = document.getElementById('filter-category');
  const filterSubcategory = document.getElementById('filter-subcategory');
  const filterFreePlan = document.getElementById('filter-free-plan');
  const clearBtn = document.getElementById('clear-filters');
  const resultsNum = document.getElementById('results-num');

  const cards = Array.from(document.querySelectorAll('.tool-card'));

  function updateSubcategoryOptions() {
    const selectedCategory = filterCategory.value;
    const subcats = selectedCategory
      ? subcategoriesByCategory[selectedCategory] || []
      : Object.values(subcategoriesByCategory).flat();

    const currentSub = filterSubcategory.value;

    // Rebuild options using DOM API only — no innerHTML
    while (filterSubcategory.firstChild) {
      filterSubcategory.removeChild(filterSubcategory.firstChild);
    }
    const defaultOpt = document.createElement('option');
    defaultOpt.value = '';
    defaultOpt.textContent = 'All Subcategories';
    filterSubcategory.appendChild(defaultOpt);

    subcats.forEach((sub) => {
      const opt = document.createElement('option');
      opt.value = sub;
      opt.textContent = sub;
      if (sub === currentSub) opt.selected = true;
      filterSubcategory.appendChild(opt);
    });

    // If current value no longer valid, reset
    if (currentSub && !subcats.includes(currentSub)) {
      filterSubcategory.value = '';
    }
  }

  function filterCards() {
    // Sanitize: strip to plain text, limit length, strip any HTML-like chars
    const rawQuery = searchInput.value.slice(0, 100).replace(/[<>"'`]/g, '');
    const query = rawQuery.toLowerCase().trim();
    // Dropdown values are constrained by <option> elements — safe, but validate
    const allowedCategories = Object.keys(subcategoriesByCategory).concat(['']);
    const allowedSubcats = Object.values(subcategoriesByCategory).flat().concat(['']);
    const allowedFreePlan = ['', 'Yes', 'No', 'Free Trial Only'];
    const category = allowedCategories.includes(filterCategory.value) ? filterCategory.value : '';
    const subcategory = allowedSubcats.includes(filterSubcategory.value) ? filterSubcategory.value : '';
    const freePlan = allowedFreePlan.includes(filterFreePlan.value) ? filterFreePlan.value : '';

    let visibleCount = 0;

    cards.forEach((card) => {
      const cardTitle = (card.dataset.title || '').toLowerCase();
      const cardCategory = card.dataset.category || '';
      const cardSubcategory = card.dataset.subcategory || '';
      const cardFreePlan = card.dataset.freeplan || '';
      const cardTagline = (card.querySelector('.tool-tagline')?.textContent || '').toLowerCase();

      const matchesQuery =
        !query ||
        cardTitle.includes(query) ||
        cardTagline.includes(query) ||
        cardCategory.toLowerCase().includes(query);

      const matchesCategory = !category || cardCategory === category;
      const matchesSubcategory = !subcategory || cardSubcategory === subcategory;
      const matchesFreePlan = !freePlan || cardFreePlan === freePlan;

      const visible = matchesQuery && matchesCategory && matchesSubcategory && matchesFreePlan;

      card.style.display = visible ? '' : 'none';
      if (visible) visibleCount++;
    });

    if (resultsNum) resultsNum.textContent = String(visibleCount);
  }

  if (searchInput) searchInput.addEventListener('input', filterCards);
  if (filterCategory) {
    filterCategory.addEventListener('change', () => {
      updateSubcategoryOptions();
      filterCards();
    });
  }
  if (filterSubcategory) filterSubcategory.addEventListener('change', filterCards);
  if (filterFreePlan) filterFreePlan.addEventListener('change', filterCards);

  if (clearBtn) {
    clearBtn.addEventListener('click', () => {
      if (searchInput) searchInput.value = '';
      if (filterCategory) filterCategory.value = '';
      if (filterFreePlan) filterFreePlan.value = '';
      updateSubcategoryOptions();
      filterCards();
    });
  }
  }); // end DOMContentLoaded
</script>

<style>
  .tool-search {
    margin-bottom: 2rem;
  }

  .search-controls {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .search-input-wrap {
    position: relative;
  }

  .search-icon {
    position: absolute;
    left: 0.875rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    padding: 0.625rem 0.875rem 0.625rem 2.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.9375rem;
    color: var(--color-text);
    background: #ffffff;
    box-sizing: border-box;
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
    font-family: inherit;
  }

  .search-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.1);
  }

  .filter-row {
    display: flex;
    gap: 0.625rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .filter-select {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.875rem;
    color: var(--color-text);
    background: #ffffff;
    cursor: pointer;
    outline: none;
    transition: border-color 0.15s;
    font-family: inherit;
    flex: 1;
    min-width: 150px;
  }

  .filter-select:focus {
    border-color: var(--color-accent);
  }

  .clear-btn {
    padding: 0.5rem 0.875rem;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    cursor: pointer;
    font-family: inherit;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }

  .clear-btn:hover {
    background: var(--color-surface);
    color: var(--color-text);
  }

  .search-results-bar {
    margin-top: 0.75rem;
  }

  .results-count {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .results-count strong {
    color: var(--color-text);
  }

  @media (max-width: 640px) {
    .filter-select {
      min-width: calc(50% - 0.3125rem);
    }
  }
</style>
