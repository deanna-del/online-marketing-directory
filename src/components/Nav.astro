---
const currentPath = Astro.url.pathname;

const categories = [
  { label: 'Business Foundation', slug: 'business-foundation' },
  { label: 'Marketing & Lead Generation', slug: 'marketing-lead-generation' },
  { label: 'Content Creation', slug: 'content-creation' },
  { label: 'AI Tools by Use Case', slug: 'ai-tools-by-use-case' },
  { label: 'Operations & Productivity', slug: 'operations-productivity' },
];
---

<nav class="nav" role="navigation" aria-label="Main navigation">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="Online Marketing Directory — Home">
      <span class="nav-logo-icon" aria-hidden="true">&#9670;</span>
      <span class="nav-logo-text">Online Marketing Directory</span>
    </a>

    <button
      class="nav-hamburger"
      id="nav-hamburger"
      aria-controls="nav-menu"
      aria-expanded="false"
      aria-label="Toggle navigation menu"
    >
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
    </button>

    <div class="nav-menu" id="nav-menu" role="menubar">
      <!-- Tools dropdown -->
      <div class="nav-item nav-dropdown-wrapper">
        <button
          class:list={['nav-link nav-dropdown-trigger', { active: currentPath.startsWith('/tools') }]}
          aria-haspopup="true"
          aria-expanded="false"
          id="tools-menu-btn"
          aria-controls="tools-dropdown"
        >
          Tools <span class="dropdown-arrow" aria-hidden="true">&#9660;</span>
        </button>
        <div class="nav-dropdown" id="tools-dropdown" role="menu" aria-labelledby="tools-menu-btn">
          <a href="/tools" class="nav-dropdown-item nav-dropdown-all" role="menuitem">
            All Tools
          </a>
          <div class="nav-dropdown-divider" role="separator"></div>
          {categories.map((cat) => (
            <a
              href={`/tools?category=${cat.slug}`}
              class="nav-dropdown-item"
              role="menuitem"
            >
              {cat.label}
            </a>
          ))}
        </div>
      </div>

      <a
        href="/training"
        class:list={['nav-link', { active: currentPath.startsWith('/training') }]}
        role="menuitem"
      >
        Recommended Training
      </a>

      <a
        href="/blog"
        class:list={['nav-link', { active: currentPath.startsWith('/blog') }]}
        role="menuitem"
      >
        Blog
      </a>
    </div>
  </div>
</nav>

<script>
  // Dropdown toggle (desktop)
  const dropdownBtn = document.getElementById('tools-menu-btn') as HTMLButtonElement | null;
  const dropdown = document.getElementById('tools-dropdown') as HTMLElement | null;

  if (dropdownBtn && dropdown) {
    dropdownBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = dropdownBtn.getAttribute('aria-expanded') === 'true';
      dropdownBtn.setAttribute('aria-expanded', String(!isOpen));
      dropdown.classList.toggle('open', !isOpen);
    });

    // Keyboard navigation
    dropdownBtn.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        dropdownBtn.setAttribute('aria-expanded', 'false');
        dropdown.classList.remove('open');
        dropdownBtn.focus();
      }
    });

    document.addEventListener('click', () => {
      dropdownBtn.setAttribute('aria-expanded', 'false');
      dropdown.classList.remove('open');
    });

    dropdown.addEventListener('click', (e) => e.stopPropagation());
  }

  // Mobile hamburger
  const hamburger = document.getElementById('nav-hamburger') as HTMLButtonElement | null;
  const navMenu = document.getElementById('nav-menu') as HTMLElement | null;

  if (hamburger && navMenu) {
    hamburger.addEventListener('click', () => {
      const isOpen = hamburger.getAttribute('aria-expanded') === 'true';
      hamburger.setAttribute('aria-expanded', String(!isOpen));
      navMenu.classList.toggle('mobile-open', !isOpen);
      hamburger.classList.toggle('is-open', !isOpen);
    });
  }

  // Mobile accordion for Tools category
  if (dropdownBtn && dropdown && navMenu) {
    const mobileToolsBtn = dropdownBtn;
    mobileToolsBtn.addEventListener('click', () => {
      if (window.innerWidth < 768) {
        dropdown.classList.toggle('mobile-accordion-open');
      }
    });
  }

  // Scroll shadow on nav
  const nav = document.querySelector('.nav') as HTMLElement | null;
  if (nav) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        nav.classList.toggle('scrolled', !entry.isIntersecting);
      },
      { threshold: 0, rootMargin: '-1px 0px 0px 0px' }
    );
    const sentinel = document.createElement('div');
    sentinel.style.height = '1px';
    document.body.prepend(sentinel);
    observer.observe(sentinel);
  }
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #001F54;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    transition: box-shadow 0.2s ease;
  }

  .nav.scrolled {
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.25);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: 2rem;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    font-weight: 700;
    font-size: 1rem;
    color: #ffffff;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .nav-logo-icon {
    color: #1282A2;
    font-size: 1.1rem;
  }

  .nav-menu {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: #B8CAE8;
    text-decoration: none;
    border-radius: var(--radius);
    border: none;
    background: none;
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: #ffffff;
    background: rgba(255,255,255,0.1);
  }

  .nav-link.active {
    color: #ffffff;
    background: rgba(18, 130, 162, 0.3);
  }

  .dropdown-arrow {
    font-size: 0.6rem;
    transition: transform 0.2s;
  }

  .nav-dropdown-trigger[aria-expanded="true"] .dropdown-arrow {
    transform: rotate(180deg);
  }

  .nav-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: 0 8px 24px rgba(0, 31, 84, 0.15);
    min-width: 240px;
    padding: 0.5rem;
    z-index: 200;
  }

  .nav-dropdown.open {
    display: block;
  }

  .nav-dropdown-item {
    display: block;
    padding: 0.5rem 0.75rem;
    font-size: 0.9rem;
    color: #001F54;
    text-decoration: none;
    border-radius: 6px;
    transition: background 0.15s, color 0.15s;
  }

  .nav-dropdown-item:hover {
    background: #E3F4F8;
    color: #1282A2;
  }

  .nav-dropdown-all {
    font-weight: 600;
  }

  .nav-dropdown-divider {
    height: 1px;
    background: var(--color-border);
    margin: 0.4rem 0.75rem;
  }

  /* Hamburger */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: var(--radius);
  }

  .nav-hamburger:hover {
    background: rgba(255,255,255,0.1);
  }

  .hamburger-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: #ffffff;
    border-radius: 2px;
    transition: transform 0.2s, opacity 0.2s;
  }

  .nav-hamburger.is-open .hamburger-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .nav-hamburger.is-open .hamburger-bar:nth-child(2) {
    opacity: 0;
  }

  .nav-hamburger.is-open .hamburger-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 767px) {
    .nav-hamburger {
      display: flex;
    }

    .nav-menu {
      display: none;
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      background: #001F54;
      border-bottom: 1px solid rgba(255,255,255,0.1);
      box-shadow: 0 8px 24px rgba(0, 31, 84, 0.3);
      padding: 0.75rem 1rem;
      gap: 0.25rem;
    }

    .nav-menu.mobile-open {
      display: flex;
    }

    .nav-link {
      width: 100%;
      justify-content: space-between;
    }

    .nav-dropdown {
      position: static;
      box-shadow: none;
      border: none;
      background: rgba(255,255,255,0.07);
      border-radius: var(--radius);
      display: none;
      padding: 0.25rem 0;
      margin-top: 0.25rem;
    }

    .nav-dropdown .nav-dropdown-item {
      color: #B8CAE8;
    }

    .nav-dropdown .nav-dropdown-item:hover {
      background: rgba(255,255,255,0.1);
      color: #ffffff;
    }

    .nav-dropdown.mobile-accordion-open {
      display: block;
    }

    .nav-item {
      display: flex;
      flex-direction: column;
    }
  }
</style>
