---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="legal-page">
    <div class="legal-container">
      <slot />
    </div>
  </div>
</BaseLayout>

<style>
  .legal-page {
    padding: 3rem 0 5rem;
  }

  .legal-container {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  :global(.legal-container h1) {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }

  :global(.legal-container .legal-meta) {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  :global(.legal-container h2) {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary);
    margin: 2rem 0 0.75rem;
  }

  :global(.legal-container h3) {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-primary);
    margin: 1.5rem 0 0.5rem;
  }

  :global(.legal-container p) {
    color: var(--color-text);
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  :global(.legal-container ul, .legal-container ol) {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  :global(.legal-container ul) {
    list-style: disc;
  }

  :global(.legal-container ol) {
    list-style: decimal;
  }

  :global(.legal-container li) {
    color: var(--color-text);
    line-height: 1.75;
    margin-bottom: 0.375rem;
  }

  :global(.legal-container a) {
    color: var(--color-accent);
    text-decoration: underline;
  }
</style>
