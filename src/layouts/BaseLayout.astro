---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  schema?: Record<string, unknown>;
}

const {
  title,
  description = 'Honest reviews of marketing tools, online courses, and training programs for coaches, course creators, and consultants.',
  ogImage = '/og-default.png',
  canonical,
  schema,
} = Astro.props;

const siteUrl = 'https://onlinemarketingdirectory.com';
const canonicalUrl = canonical ? `${siteUrl}${canonical}` : `${siteUrl}${Astro.url.pathname}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Online Marketing Directory" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Schema -->
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

    <style is:global>
      /* ===================== CSS Reset ===================== */
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
        -webkit-text-size-adjust: 100%;
      }

      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        font-size: 1rem;
        line-height: 1.6;
        color: var(--color-text);
        background: var(--color-bg);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      img, video {
        max-width: 100%;
        height: auto;
        display: block;
      }

      a {
        color: inherit;
      }

      ul, ol {
        list-style: none;
      }

      button {
        font-family: inherit;
      }

      /* ===================== CSS Custom Properties ===================== */
      :root {
        --color-primary: #001F54;
        --color-navy-mid: #034078;
        --color-accent: #1282A2;
        --color-accent-light: #E3F4F8;
        --color-text: #374151;
        --color-text-muted: #4B5563;
        --color-bg: #ffffff;
        --color-surface: #EAF2F8;
        --color-border: #e5e7eb;
        --radius: 8px;
        --font-sans: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      }

      /* ===================== Utility Classes ===================== */
      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      .section {
        padding: 4rem 0;
      }

      .section-sm {
        padding: 2.5rem 0;
      }

      .section-title {
        font-size: 1.75rem;
        font-weight: 800;
        color: var(--color-primary);
        margin-bottom: 0.5rem;
        line-height: 1.2;
      }

      .section-subtitle {
        font-size: 1rem;
        color: var(--color-text-muted);
        margin-bottom: 2rem;
        max-width: 600px;
      }

      .grid-3 {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
      }

      .grid-2 {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
      }

      @media (max-width: 1024px) {
        .grid-3 {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (max-width: 640px) {
        .grid-3, .grid-2 {
          grid-template-columns: 1fr;
        }

        .section {
          padding: 3rem 0;
        }

        .section-title {
          font-size: 1.5rem;
        }
      }

      /* ===================== Prose styles ===================== */
      .prose {
        max-width: 72ch;
        color: var(--color-text);
        line-height: 1.75;
      }

      .prose h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--color-primary);
        margin: 2rem 0 0.75rem;
        line-height: 1.3;
      }

      .prose h3 {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--color-primary);
        margin: 1.5rem 0 0.5rem;
      }

      .prose p {
        margin-bottom: 1.25rem;
      }

      .prose ul, .prose ol {
        list-style: disc;
        padding-left: 1.5rem;
        margin-bottom: 1.25rem;
      }

      .prose ol {
        list-style: decimal;
      }

      .prose li {
        margin-bottom: 0.375rem;
      }

      .prose a {
        color: var(--color-accent);
        text-decoration: underline;
      }

      .prose strong {
        font-weight: 600;
      }

      .prose blockquote {
        border-left: 4px solid var(--color-accent);
        padding-left: 1.25rem;
        font-style: italic;
        color: var(--color-text-muted);
        margin: 1.5rem 0;
      }

      /* ===================== Button globals ===================== */
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        border-radius: var(--radius);
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
        border: none;
        font-family: inherit;
        transition: background 0.15s, color 0.15s, box-shadow 0.15s, transform 0.1s;
        line-height: 1;
      }

      .btn:active {
        transform: scale(0.98);
      }

      .btn-lg {
        padding: 0.875rem 1.75rem;
        font-size: 1rem;
        font-weight: 700;
      }

      .btn-md {
        padding: 0.625rem 1.25rem;
        font-size: 0.9375rem;
        font-weight: 700;
      }

      .btn-sm {
        padding: 0.45rem 0.875rem;
        font-size: 0.9375rem;
        font-weight: 700;
      }

      .btn-primary {
        background: #1282A2;
        color: #ffffff;
      }

      .btn-primary:hover {
        background: #0e6b87;
        box-shadow: 0 4px 12px rgba(18, 130, 162, 0.35);
      }

      .btn-secondary {
        background: #ffffff;
        color: #1282A2;
        border: 2px solid #1282A2;
      }

      .btn-secondary:hover {
        background: #E3F4F8;
      }

      .btn-ghost {
        background: transparent;
        color: #1282A2;
        border: 1px solid #B3DDE8;
      }

      .btn-ghost:hover {
        background: #E3F4F8;
      }

      /* ===================== Main layout ===================== */
      main {
        flex: 1;
      }

      /* ===================== Focus visible ===================== */
      :focus-visible {
        outline: 2px solid #1282A2;
        outline-offset: 2px;
        border-radius: 3px;
      }

      /* ===================== Skip link ===================== */
      .skip-link {
        position: absolute;
        top: -100%;
        left: 0;
        background: var(--color-accent);
        color: white;
        padding: 0.5rem 1rem;
        font-weight: 600;
        text-decoration: none;
        z-index: 9999;
        border-radius: 0 0 var(--radius) 0;
      }

      .skip-link:focus {
        top: 0;
      }
    </style>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Nav />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
